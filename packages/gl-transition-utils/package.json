{
  "name": "gl-transition-utils",
  "version": "2.0.0",
  "description": "Set of utilities for GL Transitions: GLSL transform, validation and WebGL compiler",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "gl-shader": "^4.3.1",
    "gl-texture2d": "^2.1.0",
    "glsl-parser": "^2.0.1",
    "glsl-token-string": "^1.0.1",
    "glsl-tokenizer": "^2.1.5",
    "ndarray": "^1.0.19"
  },
  "devDependencies": {
    "@types/ndarray": "^1.0.14",
    "tsdown": "^0.22.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gre/gl-transition-libs.git"
  },
  "bugs": {
    "url": "https://github.com/gre/gl-transition-libs/issues"
  },
  "homepage": "https://github.com/gre/gl-transition-libs#readme"
}
